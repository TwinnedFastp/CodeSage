# 后端配置
PROJECT_NAME="ChatGPT Clone"
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=chatgpt_clone

# 如果在本地直接运行且不使用 Docker，请修改为 localhost
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/chatgpt_clone

# AI / LightRAG 模型配置
# 默认走阿里云百炼 OpenAI 兼容接口。
# 你可以只填 DASHSCOPE_API_KEY，也可以统一填 LLM_API_KEY。
# DASHSCOPE_API_KEY=sk-xxxx
# LLM_API_KEY=sk-xxxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=1024

# 如果以后想切换其它 OpenAI 兼容平台，只改这几项即可：
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536

# LightRAG 配置
LIGHTRAG_ENABLED=true
LIGHTRAG_WORKING_DIR=data/lightrag
