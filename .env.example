# 后端配置
PROJECT_NAME="ChatGPT Clone"
POSTGRES_SERVER=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=chatgpt_clone

# 如果在本地直接运行且不使用 Docker，请修改为 localhost
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/chatgpt_clone

# ---- Redis 配置（JWT 令牌黑名单 / 刷新令牌 / 登录限流）----
# 容器内访问 redis 服务；本地直连用 redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# ---- JWT 配置 ----
# 生产环境务必更换为高熵随机字符串（>=32 字节）
JWT_SECRET=please-change-this-secret-in-production
JWT_ALGORITHM=HS256
# 登录令牌（access）有效期 7 天；刷新令牌有效期 30 天
ACCESS_TOKEN_EXPIRE_DAYS=7
REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- 字段级加密密钥（Fernet，用于敏感数据加密存储）----
# 留空时由程序自动生成临时密钥（重启后历史加密数据无法解密，仅限开发）
# 生产请用 python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" 生成
FIELD_ENCRYPTION_KEY=

# ---- 邮箱验证 / SMTP 配置 ----
# 验证链接前缀（前端实际可访问的地址）
VERIFY_EMAIL_BASE_URL=http://localhost:80
# SMTP 留空时，验证邮件内容会打印到后端日志（开发模式）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ---- 登录安全策略 ----
# 连续密码错误次数上限，超过即锁定
LOGIN_MAX_FAIL_ATTEMPTS=5
# 锁定时长（分钟）
LOGIN_LOCK_MINUTES=15
# 邮箱验证链接有效期（小时）
EMAIL_VERIFY_EXPIRE_HOURS=24
# 开发模式：设为 true 时跳过邮箱验证检查（生产环境务必 false）
# SKIP_EMAIL_VERIFICATION=false

# ---- LightRAG 系统级配置 ----
# 是否启用 LightRAG 知识库（关闭后 RAG 接口会返回明确提示，普通对话仍可用）
LIGHTRAG_ENABLED=true
# LightRAG 索引/图谱/缓存文件存放目录
LIGHTRAG_WORKING_DIR=data/lightrag

# ---- AI 模型供应商配置 ----
# 模型配置已迁移至数据库（ai_providers 表），通过前端「设置 → 模型供应商」页面管理。
# 每个用户可配置多个供应商（API Key / Base URL / LLM 模型 / Embedding 模型 / 维度），
# 并启用其中一个作为当前生效配置。
#
# 首次部署流程：
#   1. 启动服务 → 2. 注册账号 → 3. 登录 → 4. 点击左下角头像 → 设置 → 模型供应商 → 添加供应商
# 添加供应商时支持预设快捷填充（智谱 GLM / 阿里百炼 / OpenAI / DeepSeek / OpenRouter）
